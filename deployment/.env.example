# ============================================================
# 环境变量配置 — 生产部署
# 复制此文件为 .env 后填写实际值：
#   cp deployment/.env.example deployment/.env
# ============================================================

# ---------- 项目根目录（docker build context） ----------
# 服务器上本项目的绝对路径，例如 /root/wd_bishe
PROJECT_ROOT=/root/wd_bishe

# ---------- Docker 镜像标签 ----------
IMAGE_TAG=latest

# ---------- 前端端口 ----------
# 对外暴露的 HTTP 端口（nginx）
FRONTEND_PORT=80

# ---------- 持久化存储目录 ----------
# 服务器上存放用户上传图像、分割结果、导出文件的目录
# 必须是一个绝对路径，且有写入权限
STORAGE_DIR=/data/sem-platform/storage

# ---------- 模型权重目录 ----------
# 包含 best.pt（MBU-Net++）、sam_vit_h_4ec893100.pth（MatSAM）等
# 只读挂载到容器内，容器内路径固定为 /models
MODEL_WEIGHTS_DIR=/data/sem-platform/models

# ---------- GPU 配置 ----------
# 是否启用 CUDA（无 GPU 时设为 false）
CUDA_ENABLED=true
# GPU 数量
GPU_COUNT=1

# ---------- Docker 基础镜像 ----------
# GPU 服务器（CUDA 12.1 + cuDNN 8）
BASE_IMAGE=nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

# CPU-only 服务器使用：
# BASE_IMAGE=ubuntu:22.04
# CUDA_ENABLED=false
