# ============================================================
# еҗҺз«Ҝ Dockerfile вҖ” GPU (CUDA) / CPU еҸҢжЁЎејҸ
#
# в–¶ GPU жңҚеҠЎеҷЁпјҲжҺЁиҚҗпјү:
#   docker build \
#     --build-arg BASE_IMAGE=nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04 \
#     -t sem-backend:gpu \
#     -f deployment/backend/Dockerfile .
#
# в–¶ CPU-only жңҚеҠЎеҷЁ:
#   docker build \
#     --build-arg BASE_IMAGE=ubuntu:22.04 \
#     --build-arg TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu \
#     -t sem-backend:cpu \
#     -f deployment/backend/Dockerfile .
#
# в–¶ иҝҗиЎҢ:
#   GPU: docker run -d --gpus all -p 8000:8000 \
#          -v /data/sem-platform/models:/models:ro \
#          -v /data/sem-platform/storage:/app/storage \
#          sem-backend:gpu
#
#   CPU: docker run -d -p 8000:8000 \
#          -v /data/sem-platform/models:/models:ro \
#          -v /data/sem-platform/storage:/app/storage \
#          sem-backend:cpu
# ============================================================

# й»ҳи®ӨдҪҝз”Ё CUDA 12.1 еҹәзЎҖй•ңеғҸпјҲruntime = ж—  NVCC зј–иҜ‘еҷЁпјҢд»…иҝҗиЎҢж—¶еә“пјү
ARG BASE_IMAGE=nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04
# PyTorch дёӢиҪҪжәҗпјҡGPU з”Ё cu121пјҢCPU з”Ё cpu
ARG TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121

# ---------- Stage 1: Base ----------
FROM ${BASE_IMAGE} AS base

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

# е®үиЈ… PythonгҖҒOpenCV дҫқиө–е’Ңеҝ…иҰҒе·Ҙе…·
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.11 python3.11-dev python3-pip \
        libgl1 libglib2.0-0 libsm6 libxext6 libxrender-dev \
        libgomp1 libhdf5-103-1 curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean \
    && ln -sf /usr/bin/python3.11 /usr/local/bin/python \
    && ln -sf /usr/bin/pip3 /usr/local/bin/pip

WORKDIR /app

# ---------- Stage 2: Python deps ----------
# е…ҲиЈ…иҪ»йҮҸдҫқиө–пјҢдёҚеҗ« torchпјҲtorch еңЁдёӢдёҖдёӘ stage иЈ…д»ҘдјҳеҢ–й•ңеғҸеұӮпјү
COPY deployment/backend/requirements.txt /tmp/requirements.txt

# иҝҮж»ӨжҺү torch/segment-anything зӣёе…ізҡ„иЎҢпјҲеҚ•зӢ¬еӨ„зҗҶпјү
RUN grep -v -E "^#|^\s*$|^torch|^segment-anything|^--|pip install torch" \
    /tmp/requirements.txt > /tmp/req_filtered.txt \
    && pip install --no-cache-dir --break-system-packages -r /tmp/req_filtered.txt

# е®үиЈ… PyTorchпјҲGPU: cu121, CPU: cpuпјү
# nvidia/cuda й•ңеғҸдёӯе·Іжңү CUDA еә“пјҢжүҖд»Ҙ --extra-index-url жүҫеҲ° cu121 wheel
# CPU й•ңеғҸж—  CUDAпјҢз”Ё cpu index
RUN pip install --no-cache-dir --break-system-packages \
        "torch>=2.2.0" "torchvision>=0.17.0" \
        --index-url "${TORCH_INDEX_URL}" \
    || pip install --no-cache-dir --break-system-packages \
        "torch>=2.2.0" "torchvision>=0.17.0"

# ---------- Stage 3: Copy code ----------
COPY backend/ /app/backend/
COPY experiments/ /app/experiments/

# еҲӣе»әеӯҳеӮЁзӣ®еҪ•
RUN mkdir -p /app/storage/runs /app/storage/exports \
             /app/storage/tmp /app/storage/logs

# еҲӣе»әйқһ root з”ЁжҲ·
RUN useradd --create-home --shell /bin/bash appuser \
    && chown -R appuser:appuser /app/storage /app/backend /app/experiments
USER appuser

ENV PYTHONPATH=/app:/app/backend:/app/experiments:$PYTHONPATH
ENV STATIC_URL_PREFIX=/static
ENV API_PREFIX=/api

# еҒҘеә·жЈҖжҹҘ
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/health')" || exit 1

# еҗҜеҠЁ uvicorn
CMD ["python", "-m", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
