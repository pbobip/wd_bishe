          <mxGeometry x="330" y="180" width="260" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="enc_title" value="&lt;b&gt;Encoder&lt;/b&gt;" style="text;html=1;fontSize=15;fontFamily=Microsoft YaHei;align=center;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1a5276;" vertex="1" parent="1">
          <mxGeometry x="380" y="190" width="160" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="enc1" value="&lt;b&gt;SE-ResNeXt50&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#444&quot;&gt;分组卷积 + SE 通道注意力&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="230" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="enc2" value="&lt;b&gt;MicroNet 预训练&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#444&quot;&gt;显微图像域特征初始化&lt;br&gt;增强纹理和微观形貌表征&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="310" width="200" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="enc3" value="多尺度特征提取&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#444&quot;&gt;Layer 0-4 → 5 级特征图&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="400" width="200" height="55" as="geometry"/>
        </mxCell>

        <!-- Encoder 设计动机标注 -->
        <mxCell id="enc_why" value="&lt;font color=&quot;#b85450&quot;&gt;⟵ 解决问题①：灰度弱对比&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;显微域预训练 &gt; ImageNet 预训练&lt;/font&gt;" style="text;html=1;fontSize=11;fontFamily=Microsoft YaHei;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="345" y="495" width="240" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="ee1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#6c8ebf;" edge="1" source="enc1" target="enc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ee2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#6c8ebf;" edge="1" source="enc2" target="enc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ===== Decoder ===== -->
        <mxCell id="dec_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#edf7ee;strokeColor=#82b366;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="660" y="180" width="260" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="dec_title" value="&lt;b&gt;Decoder&lt;/b&gt;" style="text;html=1;fontSize=15;fontFamily=Microsoft YaHei;align=center;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#2d6a2d;" vertex="1" parent="1">
          <mxGeometry x="710" y="190" width="160" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="dec1" value="&lt;b&gt;U-Net++ 解码器&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#444&quot;&gt;密集跳连 (Dense Skip Connections)&lt;br&gt;嵌套结构多路径信息融合&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="230" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="dec2" value="多尺度特征融合&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#444&quot;&gt;x_0_1, x_0_2, x_0_3, x_0_4&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="330" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="dec3" value="最终解码特征图&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#444&quot;&gt;x_0_4 → decoder_output&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="415" width="200" height="55" as="geometry"/>
        </mxCell>

        <!-- Decoder 设计动机标注 -->
        <mxCell id="dec_why" value="&lt;font color=&quot;#b85450&quot;&gt;⟵ 解决问题②：边界复杂&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;密集跳连提升细粒度结构恢复&lt;/font&gt;" style="text;html=1;fontSize=11;fontFamily=Microsoft YaHei;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="690" y="495" width="240" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="ed1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#82b366;" edge="1" source="dec1" target="dec2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#82b366;" edge="1" source="dec2" target="dec3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Encoder → Decoder -->
        <mxCell id="e_enc_dec" value="&lt;b&gt;多尺度特征&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=3;strokeColor=#333333;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="enc3" target="dec1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Input → Encoder -->
        <mxCell id="e_inp_enc" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=3;strokeColor=#333333;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="inp" target="enc_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 输出头部 ===== -->
        <!-- Seg Head -->
        <mxCell id="seg_head" value="&lt;b&gt;Seg Head&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;主分割输出&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Microsoft YaHei;fontSize=13;shadow=1;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="1020" y="210" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="seg_out" value="&lt;b&gt;分割 Mask&lt;/b&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1240" y="220" width="150" height="40" as="geometry"/>
        </mxCell>

        <!-- Edge Head -->
        <mxCell id="edge_head" value="&lt;b&gt;Edge Head&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;边界预测分支&lt;br&gt;Conv3×3 → BN → ReLU → Conv1×1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="330" width="200" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="edge_out" value="&lt;b&gt;边界图&lt;/b&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1280" y="340" width="120" height="40" as="geometry"/>
        </mxCell>

        <!-- Deep Supervision -->
        <mxCell id="deep_sup" value="&lt;b&gt;Deep Supervision&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;多尺度辅助输出监督&lt;br&gt;x_0_1, x_0_2, x_0_3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="460" width="200" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="deep_out" value="&lt;b&gt;多尺度 Logits&lt;/b&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1280" y="470" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- Decoder → Heads -->
        <mxCell id="e_d_seg" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2.5;strokeColor=#d6b656;exitX=1;exitY=0;exitDx=0;exitDy=0;" edge="1" source="dec_box" target="seg_head" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d_edge" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2.5;strokeColor=#b85450;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="dec_box" target="edge_head" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d_deep" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2.5;strokeColor=#9673a6;exitX=1;exitY=1;exitDx=0;exitDy=0;" edge="1" source="dec_box" target="deep_sup" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_seg_out" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" source="seg_head" target="seg_out" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_edge_out" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;" edge="1" source="edge_head" target="edge_out" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_deep_out" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673a6;" edge="1" source="deep_sup" target="deep_out" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- 头部设计动机 -->
        <mxCell id="head_why1" value="&lt;font color=&quot;#b85450&quot;&gt;⟵ 解决问题②：显式边界建模&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;边界标签 B = dilate(Y) − erode(Y)&lt;/font&gt;" style="text;html=1;fontSize=11;fontFamily=Microsoft YaHei;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1020" y="400" width="280" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="head_why2" value="&lt;font color=&quot;#9673a6&quot;&gt;⟵ 解决问题③：稳定小样本训练&lt;/font&gt;" style="text;html=1;fontSize=11;fontFamily=Microsoft YaHei;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1020" y="530" width="280" height="20" as="geometry"/>
        </mxCell>

        <!-- ===== 损失函数 ===== -->
        <mxCell id="loss_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="330" y="640" width="590" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="loss_title" value="&lt;b&gt;复合损失函数&lt;/b&gt;" style="text;html=1;fontSize=15;fontFamily=Microsoft YaHei;align=center;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="520" y="650" width="180" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="loss_formula" value="&lt;b&gt;L = L&lt;sub&gt;seg&lt;/sub&gt; + 0.3 × L&lt;sub&gt;edge&lt;/sub&gt; + 0.2 × L&lt;sub&gt;deep&lt;/sub&gt; + 0.1 × L&lt;sub&gt;vf&lt;/sub&gt;&lt;/b&gt;" style="text;html=1;fontSize=16;fontFamily=Microsoft YaHei;align=center;fontColor=#333;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="370" y="688" width="510" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="l1" value="&lt;b&gt;L&lt;sub&gt;seg&lt;/sub&gt;&lt;/b&gt; = Dice + BCE&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;主分割损失&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="735" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="l2" value="&lt;b&gt;L&lt;sub&gt;edge&lt;/sub&gt;&lt;/b&gt; = BCE&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;边界约束&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="735" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="l3" value="&lt;b&gt;L&lt;sub&gt;deep&lt;/sub&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;多尺度监督&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="735" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="l4" value="&lt;b&gt;L&lt;sub&gt;vf&lt;/sub&gt;&lt;/b&gt; = (mean(Ŷ)−mean(Y))²&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;统计约束&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#43a047;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="735" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="l4_why" value="&lt;font color=&quot;#43a047&quot;&gt;⬆ 解决问题④：统计稳定性&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;训练目标对齐统计目标&lt;/font&gt;" style="text;html=1;fontSize=11;fontFamily=Microsoft YaHei;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="720" y="800" width="250" height="40" as="geometry"/>
        </mxCell>

        <!-- 输出头到损失的连接 -->
        <mxCell id="el1" style="dashed=1;dashPattern=6 3;strokeWidth=1.5;strokeColor=#d6b656;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="seg_out" target="l1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="el2" style="dashed=1;dashPattern=6 3;strokeWidth=1.5;strokeColor=#b85450;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="edge_out" target="l2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="el3" style="dashed=1;dashPattern=6 3;strokeWidth=1.5;strokeColor=#9673a6;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="deep_out" target="l3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
