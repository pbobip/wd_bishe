        <!-- 标题 -->
        <mxCell id="t1" value="MBU-Net++ 模型架构" style="text;html=1;fontSize=22;fontFamily=Microsoft YaHei;align=center;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="15" width="500" height="40" as="geometry"/>
