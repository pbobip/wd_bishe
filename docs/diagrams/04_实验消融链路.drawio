          <mxGeometry x="40" y="660" width="80" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r4_content" value="&lt;b&gt;半监督伪标签验证&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Teacher=E2，91张未标注图&lt;br&gt;0.5 阈值硬伪标签，微调 30 epochs&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;验证扩样是否有收益&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#ce93d8;fontFamily=Microsoft YaHei;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="660" width="350" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r4_metric" value="Dice +0.0020 ↑&lt;br&gt;BF1 +0.0105 ↑&lt;br&gt;VF +0.0021 ↑ &lt;font color=&quot;#c62828&quot;&gt;（变差）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#ce93d8;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="660" width="310" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r4_conclusion" value="分割/边界有小幅正收益&lt;br&gt;&lt;font color=&quot;#c62828&quot;&gt;但 VF 误差变差，统计无改善&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;暂不能升格为最终方案&lt;br&gt;后续应补充高置信筛选&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#ce93d8;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="660" width="350" height="80" as="geometry"/>
