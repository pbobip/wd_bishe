        <!-- ===== E5 行 ===== -->
        <mxCell id="r5_tag" value="&lt;b&gt;E5&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;fontFamily=Microsoft YaHei;fontSize=14;fontColor=#7b1fa2;" vertex="1" parent="1">
          <mxGeometry x="40" y="790" width="80" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r5_content" value="&lt;b&gt;后处理影响评估&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;① raw（原始输出）&lt;br&gt;② remove_small（去小连通域）&lt;br&gt;③ morph_smooth（开闭运算+平滑）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#ce93d8;fontFamily=Microsoft YaHei;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="790" width="350" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r5_metric" value="remove_small: Dice +0.00003 ≈ 无变化&lt;br&gt;&lt;font color=&quot;#c62828&quot;&gt;morph_smooth: Dice=0.8996 VF=0.1117&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#c62828&quot;&gt;BF1=0.5054 —— 严重劣化&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#ce93d8;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="790" width="310" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r5_conclusion" value="remove_small 收益极小，可保留为微调&lt;br&gt;&lt;font color=&quot;#c62828&quot;&gt;&lt;b&gt;激进形态学平滑明确否定&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;后处理不是主要增益来源&lt;br&gt;不应继续堆后处理规则&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#ce93d8;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
