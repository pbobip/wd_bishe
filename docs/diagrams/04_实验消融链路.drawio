        <mxCell id="final_e2" value="&lt;b&gt;分割/边界最优：E2&lt;/b&gt;&lt;br&gt;MicroNet-U-Net++ + Edge Head + Deep Supervision&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Dice=0.9321  BF1=0.7276  VF=0.0371&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#43a047;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="980" width="440" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="final_e3" value="&lt;b&gt;⭐ 最均衡推荐：E3&lt;/b&gt;&lt;br&gt;E2 + VF Loss（统计约束）&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Dice=0.9309  BF1=0.7211  VF=0.0332&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontFamily=Microsoft YaHei;fontSize=12;shadow=1;strokeWidth=2;" vertex="1" parent="1">
