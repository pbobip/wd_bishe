        </mxCell>
        <mxCell id="h5" value="&lt;b&gt;判定&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;fontColor=#ffffff;fontFamily=Microsoft YaHei;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1210" y="90" width="100" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== E1a 行 ===== -->
        <mxCell id="r1a_tag" value="&lt;b&gt;E1a&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontFamily=Microsoft YaHei;fontSize=14;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="80" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r1a_content" value="&lt;b&gt;小样本增强对照&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;U-Net++ 无增强 vs U-Net++ 标准增强&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;验证增强方向是否正确&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontFamily=Microsoft YaHei;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="150" width="350" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r1a_metric" value="无增强 Dice=0.9281 VF=0.0339&lt;br&gt;有增强 Dice=0.9296 VF=0.0425" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="150" width="310" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r1a_conclusion" value="增强对 Dice / BF1 有轻微帮助&lt;br&gt;但 VF 变差（0.0339→0.0425）&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;增强策略偏向泛化而非统计一致性&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="150" width="350" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="r1a_status" value="✅ 通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#43a047;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=1;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="1210" y="150" width="100" height="70" as="geometry"/>
        </mxCell>

        <!-- E1a → E1 箭头 -->
        <mxCell id="arrow_1a_1" value="固定增强策略" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=3;strokeColor=#1565c0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="r1a_tag" target="r1_tag" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== E1 行 ===== -->
        <mxCell id="r1_tag" value="&lt;b&gt;E1&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontFamily=Microsoft YaHei;fontSize=14;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="80" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r1_content" value="&lt;b&gt;Baseline 三组对比&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;① U-Net&lt;br&gt;② U-Net++&lt;br&gt;③ MicroNet-pretrained U-Net++&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;分离结构收益与预训练收益&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontFamily=Microsoft YaHei;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="260" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r1_metric" value="U-Net:　　　Dice=0.9272 BF1=0.7013&lt;br&gt;U-Net++:　　Dice=0.9290 BF1=0.7093&lt;br&gt;MicroNet++: Dice=&lt;b&gt;0.9305&lt;/b&gt; BF1=&lt;b&gt;0.7188&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;U-Net++ VF=0.0302（全表最低）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="260" width="310" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r1_conclusion" value="U-Net++ &gt; U-Net（结构收益）&lt;br&gt;MicroNet-U-Net++ &gt; U-Net++（预训练收益）&lt;br&gt;&lt;b&gt;MicroNet 显微预训练有效&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;选择 MicroNet-U-Net++ 作为后续基座&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="260" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r1_status" value="✅ 通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#43a047;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=1;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="1210" y="260" width="100" height="90" as="geometry"/>
        </mxCell>

        <!-- E1 → E2 -->
        <mxCell id="arrow_1_2" value="以最优 Baseline&lt;br&gt;为基础" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=3;strokeColor=#1565c0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="r1_tag" target="r2_tag" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== E2 行 ===== -->
        <mxCell id="r2_tag" value="&lt;b&gt;E2&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f9a825;fontFamily=Microsoft YaHei;fontSize=14;fontColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="40" y="395" width="80" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r2_content" value="&lt;b&gt;边界分支消融&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;① MicroNet-U-Net++ + Edge Head&lt;br&gt;② + Edge Head + Deep Supervision&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;验证边界建模是否有效&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffe082;fontFamily=Microsoft YaHei;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="395" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r2_metric" value="+ Edge Head:&lt;br&gt;Dice=0.9283 BF1=0.7060 ❌ 无收益&lt;br&gt;+ Edge + Deep:&lt;br&gt;Dice=&lt;b&gt;0.9321&lt;/b&gt; BF1=&lt;b&gt;0.7276&lt;/b&gt; ⭐ 最优" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffe082;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="395" width="310" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r2_conclusion" value="单独 Edge Head 无稳定收益&lt;br&gt;&lt;b&gt;Edge Head + Deep Supervision 配合后有效&lt;/b&gt;&lt;br&gt;Dice 和 BF1 均达当前最高&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;边界建模需与多尺度监督配合&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffe082;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="395" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="r2_status" value="⭐ 最优" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=1;fontColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="1210" y="395" width="100" height="90" as="geometry"/>
        </mxCell>

        <!-- E2 → E3 -->
        <mxCell id="arrow_2_3" value="以最优结构&lt;br&gt;为基础" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=3;strokeColor=#f9a825;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="r2_tag" target="r3_tag" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== E3 行 ===== -->
        <mxCell id="r3_tag" value="&lt;b&gt;E3&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f9a825;fontFamily=Microsoft YaHei;fontSize=14;fontColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="40" y="530" width="80" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r3_content" value="&lt;b&gt;VF Loss 统计约束消融&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;E2 (Edge+Deep) vs E2 + VF Loss&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;验证统计目标对齐是否有效&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffe082;fontFamily=Microsoft YaHei;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="530" width="350" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r3_metric" value="E2: Dice=0.9321 VF=0.0371 BF1=0.7276&lt;br&gt;E3: Dice=0.9309 VF=&lt;b&gt;0.0332&lt;/b&gt; BF1=0.7211&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;VF↓ 0.0039（改善） Dice↓ 0.0012（代价小）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffe082;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="530" width="310" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r3_conclusion" value="&lt;b&gt;VF Loss 有效&lt;/b&gt;&lt;br&gt;用少量分割性能换统计稳定性，代价不大&lt;br&gt;&lt;b&gt;⭐ 当前最均衡方案&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;推荐作为论文主模型候选&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffe082;fontFamily=Microsoft YaHei;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="530" width="350" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="r3_status" value="⭐ 最均衡" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=1;fontColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="1210" y="530" width="100" height="80" as="geometry"/>
        </mxCell>

        <!-- E3 → E4 -->
        <mxCell id="arrow_3_4" value="主线稳定后&lt;br&gt;才进入" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=3;strokeColor=#9e9e9e;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;dashPattern=8 4;" edge="1" source="r3_tag" target="r4_tag" parent="1">
