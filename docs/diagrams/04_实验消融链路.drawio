          <mxGeometry x="1210" y="660" width="100" height="80" as="geometry"/>
        </mxCell>

        <!-- E4 → E5 -->
        <mxCell id="arrow_4_5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=3;strokeColor=#9e9e9e;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;dashPattern=8 4;" edge="1" source="r4_tag" target="r5_tag" parent="1">
