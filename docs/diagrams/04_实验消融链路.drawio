        </mxCell>
        <mxCell id="r5_status" value="❌ 否定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=1;fontColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="1210" y="790" width="100" height="80" as="geometry"/>
        </mxCell>

        <!-- ===== 最终结论区 ===== -->
        <mxCell id="final_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#43a047;shadow=1;strokeWidth=2.5;" vertex="1" parent="1">
